# ============================================
# Variables de Entorno para Coolify
# ============================================
# Copia estas variables a la sección "Environment Variables" 
# en la configuración del servicio en Coolify
# ============================================

# === PUERTOS ===
# Coolify asignará puertos automáticamente, pero puedes especificarlos
BACKEND_PORT=3210
SITE_PROXY_PORT=3211
DASHBOARD_PORT=6791

# === CONFIGURACIÓN BÁSICA (REQUERIDAS) ===
# Nombre de tu instancia
INSTANCE_NAME=convex-instance

# ⚠️ IMPORTANTE: Genera un secret seguro con: openssl rand -hex 32
INSTANCE_SECRET=CAMBIAR_POR_SECRET_SEGURO

# === URLs (IMPORTANTE: Configurar con tu dominio) ===
# Reemplaza con las URLs públicas de tu despliegue en Coolify
# Ejemplo: https://convex.tudominio.com
CONVEX_CLOUD_ORIGIN=https://tu-dominio-backend.com
CONVEX_SITE_ORIGIN=https://tu-dominio-site.com
NEXT_PUBLIC_DEPLOYMENT_URL=https://tu-dominio-backend.com

# === CONFIGURACIÓN DE COMPORTAMIENTO ===
RUST_LOG=info
DO_NOT_REQUIRE_SSL=true
DISABLE_BEACON=true
DOCUMENT_RETENTION_DELAY=172800
ACTIONS_USER_TIMEOUT_SECS=300
HTTP_SERVER_TIMEOUT_SECONDS=300
REDACT_LOGS_TO_CLIENT=false

# === BASE DE DATOS (Opcional) ===
# Descomenta y configura si usas base de datos externa
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# POSTGRES_URL=postgresql://user:password@host:5432/dbname
# MYSQL_URL=mysql://user:password@host:3306/dbname

# === S3 STORAGE (Opcional) ===
# Descomenta y configura si usas S3 para almacenamiento
# AWS_ACCESS_KEY_ID=tu-access-key
# AWS_SECRET_ACCESS_KEY=tu-secret-key
# AWS_REGION=us-east-1
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_STORAGE_FILES_BUCKET=convex-files
# S3_STORAGE_MODULES_BUCKET=convex-modules
# S3_STORAGE_SEARCH_BUCKET=convex-search
# S3_STORAGE_EXPORTS_BUCKET=convex-exports
# S3_STORAGE_SNAPSHOT_IMPORTS_BUCKET=convex-snapshots

# Para S3 compatible (MinIO, etc.)
# AWS_S3_FORCE_PATH_STYLE=true
# AWS_S3_DISABLE_CHECKSUMS=true
# AWS_S3_DISABLE_SSE=true
