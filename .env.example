# Variables de entorno para Convex Self-Hosted
# Copia este archivo a .env y configura los valores

# Puertos
PORT=3210
SITE_PROXY_PORT=3211
DASHBOARD_PORT=6791

# Configuración básica
INSTANCE_NAME=convex-instance
INSTANCE_SECRET=tu-secret-aqui-cambiar-en-produccion

# URLs
CONVEX_CLOUD_ORIGIN=http://127.0.0.1:3210
CONVEX_SITE_ORIGIN=http://127.0.0.1:3211
NEXT_PUBLIC_DEPLOYMENT_URL=http://127.0.0.1:3210

# Base de datos (opcional, si usas PostgreSQL o MySQL)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# POSTGRES_URL=postgresql://user:password@host:5432/dbname
# MYSQL_URL=mysql://user:password@host:3306/dbname

# S3 Storage (opcional, si usas S3 para almacenamiento)
# AWS_ACCESS_KEY_ID=tu-access-key
# AWS_SECRET_ACCESS_KEY=tu-secret-key
# AWS_REGION=us-east-1
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_STORAGE_FILES_BUCKET=convex-files
# S3_STORAGE_MODULES_BUCKET=convex-modules
# S3_STORAGE_SEARCH_BUCKET=convex-search
# S3_STORAGE_EXPORTS_BUCKET=convex-exports
# S3_STORAGE_SNAPSHOT_IMPORTS_BUCKET=convex-snapshots

# Configuración opcional
# RUST_LOG=info
# DOCUMENT_RETENTION_DELAY=172800
# ACTIONS_USER_TIMEOUT_SECS=300
# HTTP_SERVER_TIMEOUT_SECONDS=300
# DISABLE_BEACON=true
# DO_NOT_REQUIRE_SSL=true
# REDACT_LOGS_TO_CLIENT=false

